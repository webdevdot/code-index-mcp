# Code Index MCP - Environment Configuration Template

# Database Configuration
DATABASE_PATH=./code-index.db
DATABASE_MODE=WAL
DATABASE_CACHE_MB=128
DATABASE_MMAP_SIZE=30000000000

# Indexing Configuration
INDEX_BATCH_SIZE=100
INDEX_DEBOUNCE_MS=1000
EXCLUDED_DIRECTORIES=node_modules,.git,dist,build,.next,.venv,__pycache__,.pytest_cache,vendor,.bundle

# Supported File Extensions
SUPPORTED_LANGUAGES=javascript,typescript,python,php

# Server Configuration
SERVER_MODE=stdio
HTTP_PORT=3000
HTTP_HOST=localhost

# File Watcher Configuration
WATCHER_ENABLED=true
WATCHER_DEBOUNCE_MS=1000
WATCHER_STABILIZE_THRESHOLD=2000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Performance Tuning
MAX_SEARCH_RESULTS=1000
MAX_SYMBOL_RESULTS=500
SNIPPET_CONTEXT_LINES=3
SNIPPET_MAX_LENGTH=500

# Memory Configuration
MAX_FILE_SIZE_MB=50
BATCH_TRANSACTION_SIZE=100

# Dashboard Configuration
DB_PATH=./code-index.db
MCP_FOLDER=./
DASHBOARD_PORT=34244
AUTO_INDEX=false
BATCH_SIZE=100
DEBOUNCE_DELAY=1000
EXCLUDE_PATTERNS=node_modules,dist,build,.git,coverage
SUPPORTED_LANGUAGES=javascript,typescript,jsx,tsx,python,php

# Development
DEBUG=false
VERBOSE=false
